{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@preview/*": [
        "../packages/vscode-extension/src/preview/*"
      ]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
