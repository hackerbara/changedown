{
  "name": "@changetracks/tests",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:vitest && npm run test:mocha && npm run test:features",
    "test:vitest": "vitest run",
    "test:mocha": "mocha",
    "test:features": "cucumber-js --config features/cucumber.mjs",
    "test:vscode": "cd vscode && npm run test:features",
    "test:vscode:fast": "cd vscode && npm run test:fast",
    "test:vscode:slow": "cd vscode && npm run test:slow",
    "test:visual": "cd vscode && npm run test:visual"
  },
  "dependencies": {
    "@changetracks/core": "file:../core",
    "@changetracks/docx": "file:../docx",
    "@changetracks/lsp-server": "file:../lsp-server",
    "@changetracks/mcp": "file:../../changetracks-plugin/mcp-server",
    "@changetracks/opencode-plugin": "file:../opencode-plugin",
    "changetracks": "file:../cli",
    "changetracks-hooks": "file:../../changetracks-plugin/hooks-impl",
    "esbuild": "0.27.4",
    "happy-dom": "20.8.4",
    "vite": "8.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.3.2",
    "c8": "^10.1.0",
    "jszip": "^3.10.0",
    "mocha": "^11.3.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
