{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": ["ES2020"],
        "sourceMap": true,
        "rootDir": ".",
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "changetracks/init": ["../../cli/dist/init/index.d.ts"],
            "changetracks-vscode/internals": ["../../vscode-extension/out/internals"],
            "@changetracks/lsp-server": ["../../lsp-server/dist/index"],
            "@changetracks/lsp-server/internals": ["../../lsp-server/dist/internals"]
        }
    },
    "exclude": [
        "node_modules",
        "out"
    ]
}
