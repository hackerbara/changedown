{
  "name": "@changetracks/lsp-server",
  "version": "0.1.0",
  "description": "Language Server Protocol server for CriticMarkup editing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hackerbara/changetracks.git"
  },
  "keywords": ["lsp", "language-server", "criticmarkup", "change-tracking", "markdown"],
  "files": ["dist/", "README.md", "LICENSE"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js",
      "require": "./dist/internals.js"
    }
  },
  "bin": {
    "changetracks-lsp": "dist/bin/server.js"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "@changetracks/core": "file:../core"
  },
  "devDependencies": {
    "@types/node": "20.2.5",
    "typescript": "^5.1.3"
  }
}
