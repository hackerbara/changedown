{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "node changedown-plugin/hooks-impl/dist/adapters/cursor/pre-tool-use.js"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node changedown-plugin/hooks-impl/dist/adapters/cursor/before-mcp-execution.js"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node changedown-plugin/hooks-impl/dist/adapters/cursor/before-read-file.js"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node changedown-plugin/hooks-impl/dist/adapters/cursor/after-file-edit.js"
      }
    ],
    "stop": [
      {
        "command": "node changedown-plugin/hooks-impl/dist/adapters/cursor/stop.js"
      }
    ]
  }
}
